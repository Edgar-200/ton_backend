# TON — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.

# ─── Django Core ───────────────────────────────────────────────
SECRET_KEY=your-django-secret-key-here-change-this-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (local dev) ───────────────────────────────────────
DB_NAME=ton_db
DB_USER=ton_user
DB_PASSWORD=ton_pass
DB_HOST=localhost
DB_PORT=5432

# ─── Database (Railway production) ─────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# (Railway injects this automatically)

# ─── Cloudinary — File Storage ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Africa's Talking — SMS / OTP ──────────────────────────────
# Use 'sandbox' for development (free SMS simulation)
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key

# ─── Resend — Transactional Email ──────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@ton.co.tz

# ─── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Redis (production only) ───────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── Sentry (production only) ──────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
